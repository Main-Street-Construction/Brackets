rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.ownerUid;
    }

    function isIncomingOwner() {
      return isAuthenticated() && request.auth.uid == request.resource.data.ownerUid;
    }

    match /tournaments/{tournamentId} {
      allow read: if true;
      allow create: if isIncomingOwner();
      allow update, delete: if isOwner();
    }

    match /tournaments/{tournamentId}/participants/{participantId} {
      allow read: if true;
      allow write: if isAuthenticated() &&
        get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.ownerUid == request.auth.uid;
    }

    match /tournaments/{tournamentId}/matches/{matchId} {
      allow read: if true;
      allow write: if isAuthenticated() &&
        get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.ownerUid == request.auth.uid;
    }
  }
}
