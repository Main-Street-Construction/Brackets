rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function tournamentDoc(tournamentId) {
      return get(/databases/$(database)/documents/tournaments/$(tournamentId));
    }

    function tournamentExists(tournamentId) {
      return exists(/databases/$(database)/documents/tournaments/$(tournamentId));
    }

    function isTournamentCreator(tournamentId) {
      return isAuthenticated()
        && tournamentExists(tournamentId)
        && request.auth.uid == tournamentDoc(tournamentId).data.creatorId;
    }

    // Public live views can read started/finished tournaments.
    function canReadTournament(tournamentId) {
      return isTournamentCreator(tournamentId)
        || (tournamentExists(tournamentId)
          && (
            tournamentDoc(tournamentId).data.isStarted == true
            || tournamentDoc(tournamentId).data.isFinished == true
          ));
    }

    function hasOnlyTournamentKeys(data) {
      return data.keys().hasOnly([
        'name',
        'format',
        'isStarted',
        'isFinished',
        'inviteCode',
        'creatorId',
        'numNets',
        'queue',
        'activeNets',
        'rules',
        'createdAt'
      ]);
    }

    function validTournamentCreate() {
      return hasOnlyTournamentKeys(request.resource.data)
        && request.resource.data.creatorId == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.format is string
        && request.resource.data.inviteCode is string
        && request.resource.data.isStarted is bool
        && request.resource.data.isFinished is bool
        && request.resource.data.queue is list;
    }

    function validTournamentUpdate() {
      return hasOnlyTournamentKeys(request.resource.data)
        // creatorId is immutable after create.
        && request.resource.data.creatorId == resource.data.creatorId;
    }

    function validTeamDoc(teamId) {
      return request.resource.data.keys().hasOnly(['id', 'name', 'consecutiveWins', 'group'])
        && request.resource.data.id == teamId
        && request.resource.data.name is string
        && (!('consecutiveWins' in request.resource.data) || request.resource.data.consecutiveWins is int)
        && (!('group' in request.resource.data) || request.resource.data.group is string);
    }

    function nullableString(field) {
      return !(field in request.resource.data)
        || request.resource.data[field] == null
        || request.resource.data[field] is string;
    }

    function validMatchDoc(matchId) {
      return request.resource.data.keys().hasOnly([
          'id',
          'team1Id',
          'team2Id',
          'score1',
          'score2',
          'winnerId',
          'byeWalkover',
          'nextMatchId',
          'nextMatchSlot',
          'loserMatchId',
          'loserMatchSlot',
          'round',
          'bracketType',
          'netIndex',
          'poolGroup',
          'sets'
        ])
        && request.resource.data.id == matchId
        && request.resource.data.round is int
        && nullableString('team1Id')
        && nullableString('team2Id')
        && nullableString('winnerId')
        && nullableString('nextMatchId')
        && nullableString('loserMatchId')
        && (!('score1' in request.resource.data) || request.resource.data.score1 is int)
        && (!('score2' in request.resource.data) || request.resource.data.score2 is int)
        && (!('byeWalkover' in request.resource.data) || request.resource.data.byeWalkover is bool)
        && (!('nextMatchSlot' in request.resource.data) || request.resource.data.nextMatchSlot is int)
        && (!('loserMatchSlot' in request.resource.data) || request.resource.data.loserMatchSlot is int)
        && (!('bracketType' in request.resource.data) || request.resource.data.bracketType is string)
        && (!('netIndex' in request.resource.data) || request.resource.data.netIndex is int)
        && (!('poolGroup' in request.resource.data) || request.resource.data.poolGroup is string)
        && (!('sets' in request.resource.data) || request.resource.data.sets is list);
    }

    match /tournaments/{tournamentId} {
      allow read: if canReadTournament(tournamentId);

      allow create: if isAuthenticated()
        && validTournamentCreate();

      allow update: if isTournamentCreator(tournamentId)
        && validTournamentUpdate();

      allow delete: if isTournamentCreator(tournamentId);

      match /teams/{teamId} {
        allow read: if canReadTournament(tournamentId);
        allow create, update: if isTournamentCreator(tournamentId)
          && validTeamDoc(teamId);
        allow delete: if isTournamentCreator(tournamentId);
      }

      match /matches/{matchId} {
        allow read: if canReadTournament(tournamentId);
        allow create, update: if isTournamentCreator(tournamentId)
          && validMatchDoc(matchId);
        allow delete: if isTournamentCreator(tournamentId);
      }
    }
  }
}
